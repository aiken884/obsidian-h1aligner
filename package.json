{
    "name": "obsidian-h1aligner",
    "version": "0.5.0",
    "description": "Align your note filename with the first H1 on file switch.",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "node tests/e2e/e2e-smoke.cjs main.js",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [
        "obsidian-plugin",
        "h1",
        "filename",
        "sync"
    ],
    "author": "Aiken Lin",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@vitest/coverage-v8": "^2.1.9",
        "builtin-modules": "^5.3.0",
        "esbuild": "^0.21.0",
        "fast-check": "^4.8.0",
        "obsidian": "~1.4.11",
        "tslib": "^2.6.0",
        "typescript": "^5.6.0",
        "vitest": "^2.0.0"
    }
}
